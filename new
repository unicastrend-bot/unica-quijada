  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Open+Sans:wght@400;600&family=Great+Vibes&display=swap" rel="stylesheet" />

  <style>
    :root {
      --color-primary: #9cb199;
      --color-secondary: #a2bba1;
      --color-accent: #e8e3d8;
      --color-light: #faf8f3;
      --color-muted: #f5f3ec;
      --color-text: #414d3e;
      --color-subtle: #747d69;
      --color-gold: #d4b87b;
      --font-heading: 'Playfair Display', serif;
      --font-body: 'Open Sans', sans-serif;
      --font-script: 'Great Vibes', cursive;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      line-height: 1.6;
      color: var(--color-text);
      background-color: var(--color-muted);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    .container {
      width: 90%;
      max-width: 1200px;
      margin: 0 auto;
    }

    header {
      background-color: var(--color-light);
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 0;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      color: var(--color-primary);
    }

    .nav-links {
      list-style: none;
      display: flex;
      gap: 1.2rem;
      flex-wrap: wrap;
    }

    .nav-links a {
      font-weight: 600;
      transition: color 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--color-secondary);
    }

    .btn {
      display: inline-block;
      padding: 0.7rem 1.2rem;
      border-radius: 999px;
      background-color: var(--color-primary);
      color: #fff;
      font-weight: 600;
      transition: background-color 0.3s ease, transform 0.3s ease;
    }

    .btn:hover {
      background-color: var(--color-secondary);
      transform: translateY(-2px);
    }

    .hero {
      background-color: var(--color-light);
      padding: 4rem 0;
    }

    .hero-content {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .hero-left,
    .hero-center,
    .hero-right {
      flex: 1 1 300px;
    }

    .profile-container {
      position: relative;
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
      padding-top: 100%;
      background-color: var(--color-accent);
      border-radius: 50% 50% 40% 60% / 60% 40% 50% 50%;
      overflow: hidden;
    }

    .profile-image {
      position: absolute;
      inset: 10%;
      background-color: var(--color-muted);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-subtle);
      text-align: center;
      overflow: hidden;
    }

    .profile-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    .hero-center .intro-small {
      font-size: 0.9rem;
      color: var(--color-secondary);
      letter-spacing: 2px;
    }

    .hero-name {
      font-family: var(--font-heading);
      font-size: 2.5rem;
      color: var(--color-primary);
      margin: 0.5rem 0;
    }

    .alias {
      font-family: var(--font-script);
      font-size: 1.8rem;
      color: var(--color-gold);
      margin-bottom: 0.8rem;
    }

    .profession,
    .intro-description,
    .intro-note {
      margin-bottom: 0.8rem;
    }

    .badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .badge {
      background-color: var(--color-primary);
      color: #fff;
      padding: 0.4rem 0.8rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .contact-card {
      background-color: var(--color-accent);
      padding: 1.5rem;
      border-radius: 1rem;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
    }

    .contact-card ul {
      list-style: none;
      margin-bottom: 1rem;
    }

    .contact-card li {
      margin-bottom: 0.6rem;
      font-size: 0.95rem;
    }

    .quote {
      font-family: var(--font-script);
      color: var(--color-gold);
      font-size: 1.2rem;
    }

    .info-section,
    .features-section,
    .projects-section,
    .info-row,
    .cta-section {
      padding: 4rem 0;
    }

    .card-group,
    .feature-grid,
    .row-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .info-card,
    .feature-card,
    .row-card,
    .project-card {
      background-color: var(--color-light);
      border-radius: 1rem;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
    }

    .info-card,
    .row-card {
      flex: 1 1 300px;
      padding: 2rem;
    }

    .info-card h2,
    .features-section h2,
    .projects-section h2,
    .row-card h3,
    .cta-section h2 {
      font-family: var(--font-heading);
      color: var(--color-primary);
    }

    .info-card h2 {
      font-size: 1.6rem;
      margin-bottom: 1rem;
    }

    .card-image,
    .project-img {
      width: 100%;
      background-color: var(--color-accent);
      position: relative;
      overflow: hidden;
    }

    .card-image {
      padding-top: 56%;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
    }

    .card-image::before,
    .project-img::before {
      content: "Image";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: var(--color-subtle);
      font-size: 1rem;
    }

    .services-columns,
    .skills-tools {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    .service-category,
    .skills,
    .tools {
      flex: 1 1 200px;
    }

    .service-category h3,
    .skills h3,
    .tools h3,
    .feature-card h3 {
      font-family: var(--font-heading);
      color: var(--color-secondary);
      margin-bottom: 0.5rem;
    }

    .service-category ul,
    .feature-card ul {
      list-style: none;
    }

    .service-category li,
    .feature-card li {
      margin-bottom: 0.4rem;
      padding-left: 1rem;
      position: relative;
      font-size: 0.92rem;
    }

    .service-category li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--color-primary);
    }

    .feature-card li::before {
      content: "›";
      position: absolute;
      left: 0;
      color: var(--color-primary);
    }

    .pill-group,
    .tool-icons {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .pill {
      background-color: var(--color-primary);
      color: #fff;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      font-size: 0.8rem;
    }

    .tool {
      background-color: var(--color-accent);
      color: var(--color-text);
      padding: 0.35rem 0.7rem;
      border-radius: 0.5rem;
      font-size: 0.8rem;
      border: 1px solid var(--color-primary);
    }

    .features-section {
      background-color: var(--color-light);
    }

    .features-section h2,
    .projects-section h2 {
      font-size: 2rem;
      text-align: center;
      margin-bottom: 1rem;
    }

    .subtitle {
      text-align: center;
      max-width: 650px;
      margin: 0 auto 2rem auto;
      color: var(--color-subtle);
      font-size: 0.95rem;
    }

    .feature-card {
      flex: 1 1 250px;
      background-color: var(--color-accent);
      padding: 1.5rem;
      transition: transform 0.3s ease;
    }

    .feature-card:hover,
    .project-card:hover,
    .row-card:hover {
      transform: translateY(-4px);
    }

    .projects-section {
      background-color: var(--color-muted);
    }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .project-card {
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }

    .project-img {
      padding-top: 60%;
    }

    .project-card h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      color: var(--color-secondary);
      margin: 1rem 1rem 0.3rem 1rem;
    }

    .project-card .category {
      margin: 0 1rem;
      font-size: 0.85rem;
      color: var(--color-gold);
      font-weight: 600;
    }

    .project-card .note {
      margin: 0.5rem 1rem 1rem 1rem;
      font-size: 0.78rem;
      color: var(--color-subtle);
      font-style: italic;
    }

    .project-preview {
      display: none;
      position: fixed;
      inset: 0;
      background-color: rgba(0, 0, 0, 0.5);
      align-items: center;
      justify-content: center;
      padding: 2rem;
      z-index: 2000;
    }

    .project-preview:target {
      display: flex;
    }

    .preview-content {
      background-color: var(--color-light);
      padding: 2rem;
      border-radius: 1rem;
      max-width: 700px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
    }

    .preview-content h3 {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }

    .preview-content p {
      margin-bottom: 1rem;
    }

    .close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-size: 1.5rem;
      color: var(--color-secondary);
    }

    .testimonials .testimonial {
      margin-bottom: 1rem;
      padding-left: 1rem;
      position: relative;
      font-size: 0.92rem;
      font-style: italic;
    }

    .testimonials .testimonial::before {
      content: "— ";
      position: absolute;
      left: 0;
      color: var(--color-primary);
    }

    .cta-section {
      background-color: var(--color-primary);
      color: #fff;
      text-align: center;
    }

    .cta-section h2 {
      color: #fff;
      margin-bottom: 1rem;
    }

    .cta-section p {
      max-width: 600px;
      margin: 0 auto 2rem auto;
    }

    .cta-buttons {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .cta-buttons .btn {
      background-color: #fff;
      color: var(--color-primary);
    }

    footer {
      background-color: var(--color-secondary);
      color: #fff;
      text-align: center;
      padding: 2rem 1rem;
    }

    footer .message {
      font-size: 1rem;
      margin-bottom: 1rem;
      font-family: var(--font-script);
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      font-size: 0.95rem;
    }

    .footer-links a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .hero-content {
        flex-direction: column;
      }

      .nav {
        justify-content: center;
      }

      .nav-links {
        justify-content: center;
      }
    }
  </style>
</head>
